class Solution(object):
    def myPow(self, x, n):
        # Handle negative power
        if n < 0:
            x = 1 / x
            n = -n
        
        result = 1
        
        while n > 0:
            # If n is odd
            if n % 2 == 1:
                result *= x
            
            # Square the base
            x *= x
            n //= 2
        
        return result
